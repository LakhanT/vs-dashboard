# Production .env for Hostinger VPS — copy to /opt/vs-dashboard/backend/.env

DATABASE_URL=sqlite:////opt/vs-dashboard/backend/data/vs_dashboard.db

OHLC_DATA_SOURCE=yahoo
LIVE_PRICE_SOURCE=fyers
LIVE_PRICE_ENABLED=true
LIVE_PRICE_INTERVAL_SEC=15
LIVE_PRICE_BATCH_SIZE=100

# Your public site URL (no trailing slash)
CORS_ORIGINS=https://YOUR_DOMAIN,https://www.YOUR_DOMAIN

# Fyers — copy credentials.txt to server; login once via SSH (see deploy/hostinger/README.md)
FYERS_CREDENTIALS_FILE=/opt/vs-dashboard/backend/credentials.txt
FYERS_REDIRECT_URI=http://127.0.0.1:5000/callback

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
